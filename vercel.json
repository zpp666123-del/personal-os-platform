{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/u/styles.css", "destination": "/styles.css" },
    { "source": "/u/data.js", "destination": "/data.js" },
    { "source": "/u/app.js", "destination": "/app.js" },
    { "source": "/resume/styles.css", "destination": "/styles.css" },
    { "source": "/resume/data.js", "destination": "/data.js" },
    { "source": "/resume/app.js", "destination": "/app.js" },
    { "source": "/u/:handle", "destination": "/" },
    { "source": "/resume/:handle", "destination": "/" },
    { "source": "/home", "destination": "/" },
    { "source": "/login", "destination": "/" },
    { "source": "/dashboard", "destination": "/" },
    { "source": "/templates", "destination": "/" },
    { "source": "/pricing", "destination": "/" },
    { "source": "/inbox", "destination": "/" },
    { "source": "/studio/:section", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
